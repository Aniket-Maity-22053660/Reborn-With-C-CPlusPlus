#include<iostream>

using namespace std;

int main(){

  int num[] = {10, 20, 30, 40, 50};
  cout<<num<<endl;
  for(int i = 0 ; i < 5 ; i++){
    cout<<num + i<<endl;
  }
  putchar('\n');
  for(int i = 0 ; i < 5 ; i++){
    cout<<*(num + i)<<endl;
  }
  int *num1 = num;
  for(int i = 0 ; i < 5 ; i++){
    cout<<*(num1+i)<<" stored at memory location: "<<(num1 + i)<<endl;
  }
  int **num2 = &num1;
  for(int i = 0 ; i < 5 ; i++){
    cout<<*(*(num2) + i)<<" ";
  }
  putchar('\n');
  return 0;
}
